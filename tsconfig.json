{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {}
  },
  "include": [
    ".pi/extensions/**/*.ts",
    "tests/**/*.ts",
    "tests/**/*.mjs"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
